{
  "name": "trialmatch-ai",
  "version": "1.0.0",
  "description": "Clinical Trial Eligibility Reasoning Agent — multi-agent AI pipeline for criterion-by-criterion eligibility assessment",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=frontend",
    "test": "npm test --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}