# TrialMatch AI — Environment Variables
# Copy this file to backend/.env and frontend/.env.local and fill in your values.
# The actual .env files are gitignored — never commit them.

# ── LLM Configuration ──────────────────────────────────────────
# LLM Provider identifier (used for selection/logging)
LLM_PROVIDER=groq

# API key for the active LLM provider (e.g. Groq, OpenAI, GLM)
LLM_API_KEY=your_api_key_here

# Model string — must match the provider
LLM_MODEL=llama-4-maverick-17b-128e-instruct

# Base URL for the LLM API (OpenAI-compatible endpoint)
LLM_BASE_URL=https://api.groq.com/openai/v1

# ── Backend Configuration ──────────────────────────────────────
# Express server port
PORT=3001

# Environment: 'development' (colored logs) | 'production' (JSON logs)
NODE_ENV=development

# [Backend] CORS Allowed Origins — comma-separated list of where the frontend is hosted
# Example: http://localhost:3000,https://trially.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend Configuration ─────────────────────────────────────
# [Frontend] URL of the backend API (used for Next.js rewrites)
# Example: http://localhost:3001 or https://trially-backend.onrender.com
BACKEND_URL=http://localhost:3001

