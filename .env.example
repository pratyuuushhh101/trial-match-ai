# TrialMatch AI — Environment Variables
# Copy this file to backend/.env and fill in your values.
# The actual .env is gitignored — never commit it.

# LLM Provider identifier (for logging only — all use OpenAI-compatible format)
LLM_PROVIDER=groq

# API key for the active LLM provider
# Groq: get from console.groq.com
LLM_API_KEY=your_groq_api_key_here

# Model string — must match the provider
# Groq: llama-4-maverick-17b-128e-instruct | GLM: glm-5.1 | OpenAI: gpt-4o
LLM_MODEL=llama-4-maverick-17b-128e-instruct

# Base URL for the LLM API (OpenAI-compatible endpoint)
# Groq:   https://api.groq.com/openai/v1
# GLM:    https://open.bigmodel.cn/api/paas/v4
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://api.groq.com/openai/v1

# Express server port (frontend proxies /api/* to this)
PORT=3001

# Environment: 'development' (colored logs) | 'production' (JSON logs)
NODE_ENV=development
